{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npx next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/rescrape?tier=fast&key=lenzy-cron-2026",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/rescrape?tier=mid&key=lenzy-cron-2026",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/rescrape?tier=full&key=lenzy-cron-2026",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/celebrities?key=lenzy-cron-2026",
      "schedule": "0 */4 * * *"
    }
  ]
}
